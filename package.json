{
  "name": "watchcord",
  "version": "1.0.0",
  "description": "Watchcord is a selective alerting bot for Discord that lets you watch specific channels for important messages, keywords, or patterns. It helps you stay on top of the things you care about without needing to constantly check every noisy server.",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx watch src/index.ts",
    "deploy": "tsx src/deploy-command.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauln17/watchcord.git"
  },
